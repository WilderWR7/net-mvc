@model hello_world.Models.PersonEntity

@{
    ViewData["Title"] = "Create";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <!-- Tarjeta principal para darle un diseño de bloque limpio -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center py-3 rounded-top">
                    <h2 class="mb-0 fs-4">Create PersonEntity</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Usamos mb-3 para el espaciado vertical y form-label para las etiquetas -->
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Code" class="form-control form-control-lg bg-light" placeholder="Enter code" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="FirstName" class="form-control form-control-lg bg-light" placeholder="Enter first name" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="LastName" class="form-control form-control-lg bg-light" placeholder="Enter last name" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg bg-light" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="PhoneNumber" type="tel" class="form-control form-control-lg bg-light" placeholder="(123) 456-7890" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <!-- Botón de bloque que ocupa todo el ancho -->
                        <div class="d-grid gap-2 mt-4">
                            <input type="submit" value="Create" class="btn btn-primary btn-lg" />
                        </div>
                    </form>
                </div>
            </div>

            <!-- Enlace de regreso estilizado -->
            <div class="text-center mt-4">
                <a asp-action="Index" class="text-decoration-none text-muted hover-primary">
                    &larr; Back to List
                </a>
            </div>

        </div>
    </div>
</div>