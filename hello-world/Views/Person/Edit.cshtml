@model hello_world.Models.PersonEntity

@{
    ViewData["Title"] = "Edit";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <!-- Tarjeta principal -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center py-3 rounded-top">
                    <h2 class="mb-0 fs-4">Edit PersonEntity</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Campo oculto indispensable para mantener el ID al guardar -->
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Code" disabled class="form-control form-control-lg bg-light" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="FirstName" class="form-control form-control-lg bg-light" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="LastName" class="form-control form-control-lg bg-light" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg bg-light" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="PhoneNumber" type="tel" class="form-control form-control-lg bg-light" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <!-- Botón para guardar los cambios -->
                        <div class="d-grid gap-2 mt-4">
                            <input type="submit" value="Save Changes" class="btn btn-primary btn-lg shadow-sm" />
                        </div>
                    </form>
                </div>
            </div>

            <!-- Enlace para volver -->
            <div class="text-center mt-4">
                <a asp-action="Index" class="text-decoration-none text-muted hover-primary">
                    &larr; Back to List
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}